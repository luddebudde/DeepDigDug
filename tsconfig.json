{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [],
    "noUncheckedIndexedAccess": false,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "packages/world-generation/src/world_description",
    "packages/world-generation/src/perlinConstants.ts",
    "packages/world-generation/src/materials.ts",
    "packages/world-generation/src/items.ts",
    "packages/world-generation/src/perlin_matrix"
  ]
}
